# Copy this file to .env and fill in the values before starting.
# cp .env.example .env

# ── Tailscale ─────────────────────────────────────────────────────────────────
# Auth key from https://login.tailscale.com/admin/settings/keys
# Use a reusable/ephemeral key for servers.
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hostname shown in Tailscale admin console (optional, defaults to on-the-fly-nvs)
TS_HOSTNAME=on-the-fly-nvs

# ── Stream ────────────────────────────────────────────────────────────────────
# iPhone IP Camera Lite stream URL.
# If iPhone and server are on the same Wi-Fi, use LAN IP:
#   STREAM_URL=http://192.168.1.100:8080/video
# If on different networks (e.g. cellular), use iPhone's Tailscale IP:
#   STREAM_URL=http://100.x.x.x:8080/video
STREAM_URL=http://192.168.1.100:8080/video
