# Copy this file to .env and fill in the values before starting.
# cp .env.example .env

# Tailscale
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TS_HOSTNAME=on-the-fly-nvs

# Stream — iPhone IP Camera Lite URL
# Same Wi-Fi:  http://192.168.1.100:8080/video
# Tailscale:   http://100.x.x.x:8080/video
STREAM_URL=http://192.168.1.100:8080/video

# SSH — paste output of: cat ~/.ssh/id_ed25519.pub
# Connect: ssh -p 2222 root@<server-ip>
SSH_PUBLIC_KEY=
